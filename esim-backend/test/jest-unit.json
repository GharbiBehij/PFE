{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^prisma/(.*)$": "<rootDir>/../prisma/$1",
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "testTimeout": 15000
}
