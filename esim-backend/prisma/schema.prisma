generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum UserStatus {
  ONLINE
  OFFLINE
}

enum statusDomain {
  ESIM
  TRANSACTION
}

enum Role {
  ADMIN
  ZONE_CHIEF
  CLIENT
  SALESMAN
  CUSTOMER
}

enum CoverageType {
  LOCAL
  REGIONAL
  GLOBAL
}

enum TransactionChannel {
  B2C
  B2B2C
}

enum TransactionStatus {
  PENDING
  PENDING_PAYMENT
  PROCESSING
  PAID
  PROVISIONING
  COMPLETED
  FAILED
  SUCCEEDED
  AUTHORIZED
  EXPIRED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  TOPUP
}

enum EsimStatus {
  NOT_ACTIVE
  ACTIVE
  PROCESSING
  PENDING
  FAILED
  EXPIRED
  DELETED
}
enum providerStatus {
  SUCCESS
  FAILED 
  PENDING 
}

enum WalletStatus {
  RESERVED
  COMMITTED
  RELEASED
}

enum LedgerType {
  DEBIT
  CREDIT
}

enum LedgerReason {
  RESERVE
  COMMIT
  RELEASE
  TOP_UP
  REFUND
}

enum TopUpStatus {
  PENDING
  PENDING_PAYMENT
  PENDING_CASH
  APPROVED
  CREDITED
  REJECTED
  FAILED
}

enum TopUpAttemptStatus {
  STARTED
  SUCCEEDED
  FAILED
}

enum ActivationAttemptStatus {
  STARTED
  SUCCESS
  FAILED
  TIMED_OUT
}

enum WalletAttemptStatus {
  STARTED
  SUCCEEDED
  FAILED
}

// ── Audit enums ────────────────────────────────────────────────────────────

enum AuditLayer {
  PAYMENT
  PROVISIONING
  ACTIVATION
  WALLET
  SYSTEM
  TOP_UP
}

enum AuditTrigger {
  PAYMENT_GATEWAY
  WEBHOOK           
  PROVIDER
  WORKER
  SCHEDULER
  USER
  SYSTEM
}

enum SystemEvent {
  // ── Payment ──────────────────────────────────
  PAYMENT_INITIATED
  PAYMENT_AUTHORIZED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PAYMENT_EXPIRED
  PAYMENT_REFUNDED
  PAYMENT_WEBHOOK_RECEIVED

  // ── Wallet ───────────────────────────────────
  WALLET_RESERVED
  WALLET_COMMITTED
  WALLET_RELEASED
  WALLET_FAILED

  // ── Provisioning ─────────────────────────────
  PROVISIONING_ENQUEUED
  PROVISIONING_STARTED
  PROVISIONING_SUCCESS
  PROVISIONING_FAILED
  PROVIDER_PROCESSING
  PROVIDER_TIMEOUT
  PROVIDER_NO_RESPONSE
  PURCHASE_REQUESTED

  // ── Activation ───────────────────────────────
  ACTIVATION_REQUESTED
  ACTIVATION_PROCESSING
  ACTIVATION_SUCCESS
  ACTIVATION_FAILED

 // ── TOPUP ───────────────────────────────
  TOP_UP_INITIATED
  TOP_UP_PENDING_CASH
  TOP_UP_PENDING_PAYMENT
  TOP_UP_CASH_CONFIRMED
  TOP_UP_PAYMENT_FAILED

  // ── Realtime (Socket.IO) ─────────────────────
  SOCKET_ESIM_ACTIVATED
  SOCKET_TOPUP_SUCCESS

  // ── System ───────────────────────────────────
  RETRY_ATTEMPT
  RECONCILIATION_TRIGGERED
  ILLEGAL_TRANSITION_ATTEMPTED
}

// ── Models ─────────────────────────────────────────────────────────────────

model User {
  id                 Int        @id @default(autoincrement())
  passportId         String?    @unique
  firstname          String
  lastname           String
  email              String     @unique
  hashedPassword     String
  hashedRefreshToken String?
  isDeleted          Boolean    @default(false)
  balance            Int        @default(0)
  status             UserStatus @default(OFFLINE)
  role               Role       @default(CLIENT)
  phone              String?
  pushToken          String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  transactions       Transaction[]
  payments           Payment[]
  walletTransactions WalletTransaction[]
  walletAttempts     WalletAttempt[]
  esims              Esim[]
  segment            Segment[]
  salesmanTopUps     TopUpRequest[]  @relation("SalesmanTopUps")
  reviewedTopUps     TopUpRequest[]  @relation("ReviewerTopUps")
  topUpAttempts      TopUpAttempt[]
  auditLogs          AuditLog[]
}

model Offer {
  id             Int          @id @default(autoincrement())
  country        String
  Region         String
  Destination    String
  Category       String
  title          String
  description    String
  popularity     String
  coverageType   CoverageType @default(LOCAL)
  networkType    String       @default("4G")
  dataVolume     Int?
  countryCode    String
  validityDays   Int
  price          Int
  InternalMargin Int
  providerId     Int
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  provider     Provider      @relation(fields: [providerId], references: [id])
  transactions Transaction[]
  esims        Esim[]
}

model Transaction {
  id        Int                @id @default(autoincrement())
  status    TransactionStatus
  type      TransactionType    @default(PURCHASE)
  channel   TransactionChannel
  amount    Int
  currency  String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  userId  Int
  user    User  @relation(fields: [userId], references: [id])
  offerId Int
  offer   Offer @relation(fields: [offerId], references: [id])

  esim              Esim[]
  payment           Payment?
  walletTransaction WalletTransaction?
  walletAttempt     WalletAttempt?
  auditLogs         AuditLog[]
}

model Esim {
  id             Int        @id @default(autoincrement())
  iccid          String     @unique
  activationCode String
  status         EsimStatus
  qrCode         String?
  dataTotal      Int        @default(0)
  dataUsed       Int        @default(0)
  lastUsageSync  DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  activatedAt    DateTime?
  expiryDate     DateTime

  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  transactionId Int         @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  offerId       Int?
  offer         Offer?      @relation(fields: [offerId], references: [id])
  providerId    Int
  provider      Provider    @relation(fields: [providerId], references: [id])

  usages             Usage[]
  activationAttempts ActivationAttempt[]

  @@index([userId])
  @@index([status])
}

model Usage {
  id            Int      @id @default(autoincrement())
  remainingData Int
  recordedAt    DateTime @default(now())

  esimId Int
  esim   Esim @relation(fields: [esimId], references: [id])
}

model Payment {
  id               Int      @id @default(autoincrement())
  paymentProvider  String
  providerRefId    String
  gatewayPaymentId String?  @unique
  amount           Int
  status           String
  rawResponse      Json?
  rawPayload       Json?
  paymentUrl       String?
  clientSecret     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  transactionId Int         @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model Provider {
  id        Int      @id @default(autoincrement())
  name      String
  apiUrl    String
  apiKey    String
  createdAt DateTime @default(now())

  esims Esim[]
  offer Offer[]
}

model WalletTransaction {
  id            Int          @id @default(autoincrement())
  amount        Int
  balanceAfter  Int
  paymentMethod String
  status        WalletStatus
  createdAt     DateTime     @default(now())

  userId        Int
  user          User         @relation(fields: [userId], references: [id])
  transactionId Int?         @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  ledgerEntries WalletLedger[]
}

model WalletLedger {
  id          Int          @id @default(autoincrement())
  amount      Int
  type        LedgerType
  reason      LedgerReason
  referenceId Int?
  createdAt   DateTime     @default(now())

  walletId Int
  wallet   WalletTransaction @relation(fields: [walletId], references: [id])
}

model WalletAttempt {
  id            Int                 @id @default(autoincrement())
  amount        Int
  type          LedgerType
  status        WalletAttemptStatus
  failureReason String?
  startedAt     DateTime
  completedAt   DateTime?
  createdAt     DateTime            @default(now())

  transactionId Int         @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  userId        Int
  user          User        @relation(fields: [userId], references: [id])

  @@index([transactionId, status, startedAt])
}

// ── Audit log ──────────────────────────────────────────────────────────────

model AuditLog {
  id    String     @id @default(cuid())

  // ── Classification ───────────────────────────
  layer       AuditLayer
  event       SystemEvent
  eventVersion Int @default(1)

  // ── Who ──────────────────────────────────────
  userId        Int
  user          User   @relation(fields: [userId], references: [id])
  jobId         String?
  attemptNumber Int?
  sessionId     String?
  requestId     String?

  // ── State transition ─────────────────────────
  // String instead of enum so it handles both
  // TransactionStatus and EsimStatus in one field
  fromStatus  String?
  toStatus    String
  statusDomain  statusDomain
  

  // ── Why ──────────────────────────────────────
  triggeredBy   AuditTrigger
  trigger       String?       // free-form detail e.g. "flouci_webhook"

  // ── Timing ───────────────────────────────────
  durationMs        Int?
  providerLatencyMs Int?

  // ── Context ──────────────────────────────────
  providerCode    String?   // denormalized for query speed
  paymentProvider String?   // e.g. "FLOUCI", "STRIPE"
  message         String?
  details         Json?

  createdAt DateTime @default(now())

  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  // ── Indexes for analytics + ML ───────────────
  @@index([transactionId, createdAt])   // full timeline per transaction
  @@index([layer, event])               // filter by system area
  @@index([event, triggeredBy])         // causal analysis
  @@index([userId, createdAt])          // per-user history
  @@index([providerCode, event])        // provider performance
  @@index([createdAt])                  // ETL export window
}

// ── Supporting models ──────────────────────────────────────────────────────

model Segment {
  id          Int    @id
  name        String
  description String

  userId Int
  User   User @relation(fields: [userId], references: [id])
}

model TopUpRequest {
  id               Int         @id @default(autoincrement())
  amount           Int
  currency         String      @default("TND")
  paymentMethod    String
  status           TopUpStatus @default(PENDING)
  gatewayPaymentId String?
  paymentUrl       String?
  failureReason    String?
  creditedAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  salesmanId Int
  salesman   User  @relation("SalesmanTopUps", fields: [salesmanId], references: [id])
  reviewedBy Int?
  reviewer   User? @relation("ReviewerTopUps", fields: [reviewedBy], references: [id])

  topUpAttempt TopUpAttempt?

  @@index([salesmanId, status])
}

model TopUpAttempt {
  id            Int                @id @default(autoincrement())
  amount        Int
  status        TopUpAttemptStatus
  failureReason String?
  startedAt     DateTime
  completedAt   DateTime?
  createdAt     DateTime           @default(now())

  topUpRequestId Int          @unique
  topUpRequest   TopUpRequest @relation(fields: [topUpRequestId], references: [id])
  userId         Int
  user           User         @relation(fields: [userId], references: [id])

  @@index([topUpRequestId, status, startedAt])
}

model ActivationAttempt {
  id                Int                     @id @default(autoincrement())
  attemptNumber     Int
  status            ActivationAttemptStatus
  providerRequestId String                  @unique
  providerResponse  Json?
  errorCode         String?
  errorMessage      String?
  startedAt         DateTime
  completedAt       DateTime?
  createdAt         DateTime                @default(now())

  esimId Int
  esim   Esim @relation(fields: [esimId], references: [id])

  @@index([esimId, status])
  @@index([esimId, attemptNumber])
}
