generator client {
  provider = "prisma-client-js"
}

generator nestjsDto {
  provider            = "prisma-generator-nestjs-dto"
  output              = "../src/Esim/Dto"
  classValidation     = "true"
  modelNamingStrategy = "pascal"
  dtoSuffix           = "Dto"
  createDtoPrefix     = "Create"
  updateDtoPrefix     = "Update"
  deleteDtoPrefix     = "Delete"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ONLINE
  OFFLINE
}

enum Role {
  ADMIN
  CLIENT
  SALESMAN
  CUSTOMER
}
enum CoverageType {
  LOCAL
  REGIONAL 
  GLOBAL
}
enum EsimStatus {
  NOT_ACTIVE
  ACTIVE
  PROCESSING
  PENDING
  EXPIRED
  DELETED
}

enum TransactionStatus {
  PENDING
  PROCESSING
  FAILED
  SUCCEEDED
}

enum TransactionChannel {
  B2C
  B2B2C
}

enum WalletStatus {
  RESERVED
  COMMITTED
  RELEASED
}

enum LedgerType {
  DEBIT
  CREDIT
}

enum LedgerReason {
  RESERVE
  COMMIT
  RELEASE
  TOP_UP
  REFUND
}

enum TopUpStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivationAttemptStatus {
  STARTED
  SUCCESS
  FAILED
  TIMED_OUT
}
enum OfferCategory {
  STUDENT
  STREAMER
  INFLUENCER
}

enum EsimEventStatus {
  PROVIDER_PROCESSING
  PROVIDER_TIMEOUT
  PROVISIONING_STARTED
  PROVISIONING_SUCCESS
  PROVISIONING_FAILED
  RETRY_ATTEMPT
  ACTIVATION_REQUESTED
  ACTIVATION_SUCCESS
  ACTIVATION_FAILED
  TIMEOUT
  NO_RESPONSE
  PURCHASE_REQUESTED
  PAYMENT_PROCESSING
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  WALLET_FAILED
}

model User {
  id                 Int        @id @default(autoincrement())
  passportId         String?    @unique
  firstname          String
  lastname           String
  email              String     @unique
  hashedPassword     String
  hashedRefreshToken String?
  isDeleted          Boolean    @default(false)
  balance            Int        @default(0)
  status             UserStatus @default(OFFLINE)
  role               Role       @default(CLIENT)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  transactions       Transaction[]
  payments           Payment[]
  walletTransactions WalletTransaction[]
  esims              Esim[]
  segment            Segment[]
  
  phone              String?

  salesmanTopUps     TopUpRequest[] @relation("SalesmanTopUps")
  reviewedTopUps     TopUpRequest[] @relation("ReviewerTopUps")
}

model Offer {
  id             Int    @id @default(autoincrement())
  country        String
  Region         String
  Destination    String
  Category       String 
  title          String
  description    String
  popularity     String
  coverageType   CoverageType  @default(LOCAL)
  dataVolume     Int
  validityDays   Int
  price          Int
  InternalMargin Int
  providerId     Int
  isDeleted Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])

  transactions Transaction[]
  esims        Esim[]
}

model Transaction {
  id       Int                @id @default(autoincrement())
  status   TransactionStatus
  channel  TransactionChannel
  amount   Int
  currency String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  offerId Int
  offer   Offer @relation(fields: [offerId], references: [id])

  esim Esim[]

  payment Payment?

  walletTransaction WalletTransaction?
  EsimAuditLog      EsimAuditLog[]
}

model Esim {
  id             Int             @id @default(autoincrement())
  iccid          String          @unique
  activationCode String
  status         EsimStatus
  event          EsimEventStatus
  qrCode         String?
  dataTotal      Int             @default(0)
  dataUsed       Int             @default(0)
  lastUsageSync  DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  activatedAt DateTime?
  expiryDate  DateTime

  userId Int
  user   User @relation(fields: [userId], references: [id])

  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  offerId  Int?
  offer    Offer?   @relation(fields: [offerId], references: [id])

  providerId Int
  provider   Provider @relation(fields: [providerId], references: [id])

  usages             Usage[]
  activationAttempts ActivationAttempt[]

  @@index([userId])
  @@index([status])
}

model Usage {
  id            Int      @id @default(autoincrement())
  remainingData Int
  recordedAt    DateTime @default(now())

  esimId Int
  esim   Esim @relation(fields: [esimId], references: [id])
}

model Payment {
  id              Int    @id @default(autoincrement())
  paymentProvider String
  providerRefId   String
  amount          Int
  status          String
  rawResponse     Json?

  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  transactionId Int         @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model Provider {
  id     Int    @id @default(autoincrement())
  name   String
  apiUrl String
  apiKey String

  createdAt DateTime @default(now())

  esims Esim[]
  offer Offer[]
}

model WalletTransaction {
  id            Int          @id @default(autoincrement())
  amount        Int
  paymentMethod String
  status        WalletStatus
  balanceAfter  Int

  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  transactionId Int?         @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  ledgerEntries WalletLedger[]
}

model WalletLedger {
  id          Int          @id @default(autoincrement())
  amount      Int
  type        LedgerType   
  reason      LedgerReason 
  referenceId Int?         

  createdAt DateTime @default(now())

  walletId  Int
  wallet    WalletTransaction @relation(fields: [walletId], references: [id])
}

model EsimAuditLog {
  id        String          @id @default(cuid())
  userId    Int
  jobId     String?
  event     EsimEventStatus 
  status    EsimStatus 
  message   String?
  details   Json?
  createdAt DateTime        @default(now())

  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model Segment {
  id          Int    @id
  name        String
  description String

  userId Int
  User   User @relation(fields: [userId], references: [id])
}

model TopUpRequest {
  id          Int          @id @default(autoincrement())
  salesmanId  Int
  amount      Float
  status      TopUpStatus  @default(PENDING)
  reviewedBy  Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  salesman    User         @relation("SalesmanTopUps", fields: [salesmanId], references: [id])
  reviewer    User?        @relation("ReviewerTopUps", fields: [reviewedBy], references: [id])
}

model ActivationAttempt {
  id                String                  @id @default(cuid())
  attemptNumber     Int
  status            ActivationAttemptStatus
  providerRequestId String                  @unique
  providerResponse  Json?
  errorCode         String?
  errorMessage      String?
  startedAt         DateTime
  completedAt       DateTime?
  createdAt         DateTime                @default(now())

  esimId Int
  esim   Esim @relation(fields: [esimId], references: [id])

  @@index([esimId, status])
  @@index([esimId, attemptNumber])
}
